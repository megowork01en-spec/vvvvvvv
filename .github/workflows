name: Run Python Script

# تحديد متى يتم تشغيل الأكشن (عند عمل Push)
on: [push]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      # 1. جلب الكود من المستودع
      - name: Checkout code
        uses: actions/checkout@v3

      # 2. إعداد بيئة بايثون
      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'

      # 3. تثبيت المكتبات (اختياري - إذا كان لديك ملف requirements.txt)
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          # pip install -r requirements.txt

      # 4. تشغيل كود البايثون
      - name: Run script
        run: |
          python -c "print('Hello from GitHub Actions!'); print('Python script executed successfully.')"
